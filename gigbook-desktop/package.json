{
  "name": "gigbook-desktop",
  "version": "0.2.0",
  "description": "GigBook Server - Escritorio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.gigbook.desktop",
    "productName": "GigBook Server",
    "directories": {
      "output": "dist"
    },
    "files": [
      "../gigbook-server/**/*",
      "!**/node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.icns"
    },
    "portable": {
      "artifactName": "GigBook-Server-Portable.exe"
    }
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1"
  }
}
