{
  "name": "gigbook-desktop",
  "version": "0.2.0",
  "description": "GigBook Server - Escritorio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.gigbook.desktop",
    "productName": "GigBook Server",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "icon.png",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "../gigbook-server",
        "to": "gigbook-server",
        "filter": [
          "**/*",
          "!node_modules/.cache",
          "!data"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.icns"
    },
    "portable": {
      "artifactName": "GigBook-Server-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "pkg": "^5.8.1"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
